# Argus — environment variable TEMPLATE (committed; contains NO secrets)
# ---------------------------------------------------------------------------
# To use:  cp .env.example .env   then paste real values into .env (gitignored).
# Free-tier only (Law 3). Where each value must be configured (blueprint §13):
#   • GitHub Actions repo secrets  → ALL variables below (heavy/scheduled jobs)
#   • Vercel env vars              → only TELEGRAM_*, SUPABASE_*, GH_DISPATCH_PAT
#   • local .env                   → all, for local runs/tests
# ---------------------------------------------------------------------------

# ── Data sources ────────────────────────────────────────────────────────────
# Tiingo — primary EOD prices (free ~50 symbols/hr). https://www.tiingo.com/account/api/token
TIINGO_API_KEY=

# Alpha Vantage — news & sentiment ONLY (free 25 req/day, reserved 100% for news).
# https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# FRED — macro series (free). https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Finnhub — earnings calendar (free). https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ── LLM ─────────────────────────────────────────────────────────────────────
# Anthropic — Haiku headline scoring + Sonnet digest synthesis.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Portfolio: IBKR Flex Web Service ────────────────────────────────────────
# Flex TOKEN is the secret (read-only, 1-yr expiry — surfaced in /health).
# Flex QUERY ID is just an identifier (not secret) but required to fetch.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# ── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather (secret). Used by the Vercel webhook + push jobs.
TELEGRAM_BOT_TOKEN=
# Destination chat id for digests/warnings (not secret, but required).
TELEGRAM_CHAT_ID=
# Webhook shared secret — MUST equal the secret_token passed to setWebhook. Telegram echoes it in
# the X-Telegram-Bot-Api-Secret-Token header on every webhook POST; the Vercel webhook fail-closes
# (rejects all) when this is unset. Generate once:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# VERCEL-ONLY: scheduled/push jobs never receive webhooks — do NOT add it as a GitHub Actions
# secret. Allowed chars: A-Z a-z 0-9 _ - (Telegram constraint).
TELEGRAM_WEBHOOK_SECRET=

# ── Supabase (the spine) ────────────────────────────────────────────────────
# Project URL is NOT secret. SERVICE_ROLE key IS secret — it bypasses RLS, so it
# is server-side only (GitHub Actions / Vercel) and must NEVER reach a browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub PAT (Vercel → Actions trigger) ───────────────────────────────────
# Fine-grained PAT scoped ONLY to workflow_dispatch on this repo (used by Vercel
# for /pulse and /analyze). NOTE: named GH_* not GITHUB_* — GitHub Actions
# reserves the GITHUB_ secret-name prefix. https://github.com/settings/tokens
GH_DISPATCH_PAT=
# Target repo "owner/name" for the /pulse workflow_dispatch call (e.g. omarovski-27/argus).
# Not secret. Named GH_* (not GITHUB_*) for the same reserved-prefix reason above.
GH_REPO=
