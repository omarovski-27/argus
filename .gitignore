# ── Secrets (Law 3 / §13: never in repo) ─────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ── Virtual environments ─────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Vercel / serverless ──────────────────────────────────────────────
.vercel/

# ── Node (Vercel tooling, if pulled) ─────────────────────────────────
node_modules/

# ── Notebooks / local data scratch ───────────────────────────────────
.ipynb_checkpoints/
*.log
*.sqlite
*.db
data/local/

# ── Dry-run scratch (frozen bundle for synthesis-prompt iteration) ───
_bundle_dryrun.json
*_dryrun.json

# ── Local throwaway diagnostics — root-level `_name.py` scratch scripts ──────
# Underscore-prefixed Python at the REPO ROOT is one-off local tooling (e.g. _flex_timing.py),
# never committed: it may thread live tokens through ad-hoc httpx calls outside the wrapped,
# token-redacting fetchers (Law 3 / §13). Root-anchored so it can't touch package __init__.py
# (those live in subdirs) or the tracked conftest.py.
/_*.py

# ── Editor / OS cruft ────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db
desktop.ini
